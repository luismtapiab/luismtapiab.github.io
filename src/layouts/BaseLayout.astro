---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Lang } from "../data/i18n";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  image?: string;
  wideContent?: boolean;
  showDefaultImage?: boolean;
}

const {
  lang,
  title,
  description,
  image,
  wideContent = false,
  showDefaultImage = true,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      lang={lang}
      showDefaultImage={showDefaultImage}
    />
    <script is:inline>
      const SCROLL_KEY = "lang-switch-scroll-pos";

      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      function saveScroll() {
        const height = document.documentElement.scrollHeight - window.innerHeight;
        const percentage = height > 0 ? window.scrollY / height : 0;
        sessionStorage.setItem(SCROLL_KEY, percentage.toString());
      }

      function restoreScroll() {
        const savedPos = sessionStorage.getItem(SCROLL_KEY);
        if (savedPos) {
          const height = document.documentElement.scrollHeight - window.innerHeight;
          const target = parseFloat(savedPos) * height;
          window.scrollTo(0, target);
          setTimeout(() => sessionStorage.removeItem(SCROLL_KEY), 100);
        }
      }

      // Initial load
      restoreScroll();

      // For ClientRouter (View Transitions)
      document.addEventListener("astro:after-swap", restoreScroll);

      document.addEventListener("click", (e) => {
        const toggle = e.target.closest(".lang-toggle");
        if (toggle) saveScroll();
      });

      // Background prefetch for main pages after delay
      (function () {
        const lang = document.documentElement.lang || "en";
        const mainPages = [`/${lang}`, `/${lang}/blog`, `/${lang}/about`];

        setTimeout(() => {
          mainPages.forEach((url) => {
            if (url !== window.location.pathname) {
              const link = document.createElement("link");
              link.rel = "prefetch";
              link.href = url;
              document.head.appendChild(link);
            }
          });
        }, 10000); // 10 second delay
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} />
    <main class:list={[{ wide: wideContent }]}>
      <slot />
    </main>
    <Footer lang={lang} />
    <style>
      main.wide {
        max-width: var(--max-w-wide);
      }
    </style>
  </body>
</html>
