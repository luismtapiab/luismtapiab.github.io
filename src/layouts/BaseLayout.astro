---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../data/i18n';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  image?: string;
  wideContent?: boolean;
  showDefaultImage?: boolean;
}

const { lang, title, description, image, wideContent = false, showDefaultImage = true } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      image={image} 
      lang={lang} 
      showDefaultImage={showDefaultImage} 
    />
    <script is:inline>
      const SCROLL_KEY = 'lang-switch-scroll-pos';

      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }

      function saveScroll() {
        sessionStorage.setItem(SCROLL_KEY, window.scrollY.toString());
      }

      function restoreScroll() {
        const savedPos = sessionStorage.getItem(SCROLL_KEY);
        if (savedPos) {
          window.scrollTo(0, parseInt(savedPos, 10));
          setTimeout(() => sessionStorage.removeItem(SCROLL_KEY), 100);
        }
      }

      // Initial load
      restoreScroll();

      // For ClientRouter (View Transitions)
      document.addEventListener('astro:after-swap', restoreScroll);

      document.addEventListener('click', (e) => {
        const toggle = e.target.closest('.lang-toggle');
        if (toggle) saveScroll();
      });
    </script>
  </head>
  <body>
    <Header lang={lang} />
    <main class:list={[{ wide: wideContent }]}>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style>
  main.wide {
    max-width: var(--max-w-wide);
  }
</style>
