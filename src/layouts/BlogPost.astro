---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { Lang } from '../data/i18n';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroImageFit, lang } = Astro.props;
---

<BaseLayout lang={lang as Lang} title={title} description={description} image={heroImage}>
  <article>
    {heroImage && (
      <div class="hero-image">
        <img 
          class={heroImageFit === 'contain' ? 'fit-contain' : ''}
          width={960} 
          height={480} 
          src={heroImage} 
          alt="" 
        />
      </div>
    )}
    <div class="post-header">
      <p class="date">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <span class="updated"> · updated <FormattedDate date={updatedDate} /></span>
        )}
      </p>
      <h1>{title}</h1>
      <hr />
    </div>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .hero-image {
    margin: -3em -1em 2em;
  }
  .hero-image img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 0 0 12px 12px;
    box-shadow: var(--shadow-md);
  }

  .hero-image img.fit-contain {
    object-fit: contain;
    background: var(--card-bg);
    padding: 2rem;
  }

  .post-header {
    margin-bottom: 2em;
  }

  .date {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.5em;
  }

  .updated {
    font-style: italic;
  }

  h1 {
    margin-bottom: 0.5em;
  }

  .prose {
    line-height: 1.8;
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin-top: 2em;
  }
</style>
