---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { Image } from "astro:assets";
import type { Lang } from "../data/i18n";

type Props = CollectionEntry<"blog">["data"] & {
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageForList,
  heroImageFit,
  lang,
  prevPost,
  nextPost,
} = Astro.props;
---

<BaseLayout
  lang={lang as Lang}
  title={title}
  description={description}
  image={heroImageForList || heroImage}
  showDefaultImage={false}
>
  <article>
    {
      heroImage && (
        <div class="hero-image">
          <Image
            class={heroImageFit === "contain" ? "fit-contain" : ""}
            width={960}
            height={480}
            src={heroImage}
            alt=""
            loading="eager"
          />
        </div>
      )
    }
    <div class="post-header">
      <p class="date">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span class="updated">
              {" "}
              · updated <FormattedDate date={updatedDate} />
            </span>
          )
        }
      </p>
      <h1>{title}</h1>
      <hr />
    </div>
    <div class="prose">
      <slot />
    </div>

    {
      (prevPost || nextPost) && (
        <nav class="post-navigation">
          <div class="nav-item prev">
            {prevPost && (
              <a href={`/${lang}/blog/${prevPost.id.replace(`${lang}/`, "").replace(/\.mdx?$/, "")}`}>
                <span class="nav-label">← {lang === 'es' ? 'Anterior' : 'Previous'}</span>
                <span class="nav-title">{prevPost.data.title}</span>
              </a>
            )}
          </div>
          <div class="nav-item next">
            {nextPost && (
              <a href={`/${lang}/blog/${nextPost.id.replace(`${lang}/`, "").replace(/\.mdx?$/, "")}`}>
                <span class="nav-label">{lang === 'es' ? 'Siguiente' : 'Next'} →</span>
                <span class="nav-title">{nextPost.data.title}</span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </article>
</BaseLayout>

<style>
  .hero-image {
    margin: -3em -1em 2em;
  }
  .hero-image img {
    width: 100%;
    height: auto;
    object-fit: contain;
    background: var(--bg-offset);
    border-radius: 0 0 12px 12px;
    box-shadow: var(--shadow-md);
  }

  .hero-image img.fit-contain {
    padding: 2rem;
  }

  .post-header {
    margin-bottom: 2em;
  }

  .date {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.5em;
  }

  .updated {
    font-style: italic;
  }

  h1 {
    margin-bottom: 0.5em;
  }

  .prose {
    line-height: 1.8;
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin-top: 2em;
  }

  .post-navigation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .nav-item a {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    padding: 1rem;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    transition: transform var(--transition), border-color var(--transition);
    height: 100%;
  }

  .nav-item a:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .nav-item.next {
    text-align: right;
  }

  .nav-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .nav-title {
    font-weight: 600;
    color: var(--accent);
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .post-navigation {
      grid-template-columns: 1fr;
    }
  }
</style>
